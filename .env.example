# Project ALPHA configuration — copy to `.env` and uncomment what you want to change.
# Real environment variables take precedence over this file (pydantic-settings).
# All settings are optional; the defaults shown here work out of the box.

# Root directory for the raw data store, snapshots, and all run artifacts.
#ALPHA_DATA_DIR=data

# Master random seed — every stochastic component (gauntlet child seeds, Kronos
# sampling) derives from it, so one value pins the whole run.
#ALPHA_RANDOM_SEED=7

# Where `alpha forecast pull` stores Kronos weights (default: <data_dir>/models).
#ALPHA_WEIGHTS_DIR=data/models
